def arg_value(argv: list[str], index: int, option: str) -> str:
    if index + 1 >= len(argv) or argv[index + 1] == "":
        quit_with(f"Missing value for {option}")
    return argv[index + 1]


def set_plan(opts: Options, path: str) -> None:
    if opts.plan_seen:
        quit_with("Provide the plan path once")
    opts.plan_seen = 1
    opts.plan_explicit = True
    opts.plan_path = path


@dataclass(frozen=True)
class LogRow:
    path: str
    filename: str
    agent: str
    run_timestamp: str
    generation: str


def read_log_rows(workdir: Path) -> list[LogRow]:
    rows: list[LogRow] = []
    for path in sorted(workdir.glob("psp_*_gen*.log")):
        match = re.match(r"^psp_(.+)_([0-9]{8}T[0-9]{6}Z)_gen([0-9]+)\.log$", path.name)
        if match is None:
            continue
        agent, run_timestamp, generation = match.groups()
        rows.append(
            LogRow(
                path=str(path),
                filename=path.name,
                agent=agent,
                run_timestamp=run_timestamp,
                generation=str(int(generation)),
            )
        )
    rows.sort(key=lambda row: (row.run_timestamp, int(row.generation), row.filename))
    return rows



def pick_goal_with_fzf(script_path: Path, extra_args: list[str]) -> None:
    if shutil.which("fzf") is None:
        quit_with("fzf not found on PATH")
    psp = shlex.quote(str(script_path))
    extra = " ".join(shlex.quote(a) for a in extra_args)
    os.execvp("sh", ["sh", "-c", f"goal=$({psp} --history | fzf) && printf '%s' \"$goal\" | {psp} {extra}"])


def build_history_fzf_command(script_path: Path, extra_args: list[str]) -> str:
    psp = shlex.quote(str(script_path))
    extra = " ".join(shlex.quote(a) for a in extra_args)
    return f"goal=$({psp} --history | fzf) && printf '%s' \"$goal\" | {psp} {extra}"


def read_history_goals(psp_dir: Path) -> list[str]:
    history_path = psp_dir / "history"
    if not history_path.is_file():
        return []
    seen: set[str] = set()
    goals: list[str] = []
    for line in history_path.read_text(encoding="utf-8").splitlines():
        goal = line if "\t" not in line else (line.split("\t")[4] if len(line.split("\t")) >= 5 else "")
        if goal and goal not in seen:
            seen.add(goal)
            goals.append(goal)
    return goals


def print_history(psp_dir: Path) -> int:
    goals = read_history_goals(psp_dir)
    if not goals:
        print("No history yet.", file=sys.stderr)
        return 0
    plain = "\n".join(goals) + "\n"
    if sys.stdout.isatty():
        pager = os.environ.get("PAGER", "").strip()
        pager_cmd = shlex.split(pager) if pager else ["less", "-FRX", "+G"]
        if pager_cmd and pager_cmd[0] == "less" and "+G" not in pager_cmd:
            pager_cmd.append("+G")
        if pager_cmd and shutil.which(pager_cmd[0]):
            spaced = re.sub(r"^", "\n", plain, flags=re.M)
            subprocess.run(pager_cmd, input=spaced, text=True, check=False)
            return 0
    sys.stdout.write(plain)
    return 0


def print_logs(workdir: Path) -> int:
    rows = read_log_rows(workdir)
    if not rows:
        print("No generation logs found in current directory.", file=sys.stderr)
        return 0

    for row in rows:
        print(row.path)
    return 0


