# ── Signal handling for graceful shutdown ────────────────────────────────────
_shutdown_requested = False
_current_proc: subprocess.Popen | None = None

def _handle_signal(signum: int, frame: Any) -> None:
    global _shutdown_requested
    _shutdown_requested = True
    if _current_proc is not None and _current_proc.poll() is None:
        _current_proc.terminate()

def _register_signal_handlers() -> None:
    signal.signal(signal.SIGTERM, _handle_signal)
    try:
        signal.signal(signal.SIGINT, _handle_signal)
    except OSError:
        pass  # SIGINT may be blocked in some contexts

# ── Terminal colours (disabled when stdout is not a tty or --no-color) ───────
_COLOR_ENABLED: bool = True
_COLOR_CODES = {
    "0": "0", "1": "1", "2": "2",
    "36": "36", "32": "32", "33": "33", "31": "31", "95": "95",
}

def _color(code: str) -> str:
    """Return ANSI escape for a code, or empty string."""
    return f"\033[{code}m"

def _c(code: str) -> str:
    """Return the raw ANSI code string used by c()."""
    return code

def _init_colors() -> None:
    """Initialize color code constants after color mode is known."""
    global RESET, BOLD, DIM, CYAN, GREEN, YELLOW, RED, PINK, SEP, LINE
    RESET  = _c("0")
    BOLD   = _c("1")
    DIM    = _c("2")
    CYAN   = _c("36")
    GREEN  = _c("32")
    YELLOW = _c("33")
    RED    = _c("31")
    PINK   = _c("95")
    SEP    = "|"
    LINE   = "-"


def c(text: str, *codes: str) -> str:
    """Wrap text in ANSI codes (no-op when colors disabled)."""
    if not _COLOR_ENABLED:
        return text
    opens = "".join(_color(code) for code in codes)
    return f"{opens}{text}{_color('0')}"


