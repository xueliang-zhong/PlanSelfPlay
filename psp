def warn_if_no_agent() -> None:
    missing = [name for name, _ in _AGENT_INSTALL_HINTS if shutil.which(name) is None]
    if len(missing) < len(_AGENT_INSTALL_HINTS):
        return  # at least one agent present
    print("\nNo agent found on PATH. Install one to get started:")
    for name, hint in _AGENT_INSTALL_HINTS:
        print(f"  {name:<10}→  {hint}")
    print()


def append_history(opts: Options, plan_display: str) -> None:
    opts.psp_dir.mkdir(parents=True, exist_ok=True)
    history_path = opts.psp_dir / "history"
    raw = opts.goal_text if opts.goal_text else f"(plan: {plan_display})"
    goal_field = " ".join(raw.split())
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    with history_path.open("a", encoding="utf-8") as handle:
        handle.write(f"{timestamp}\t{opts.agent}\t{Path.cwd()}\tg={opts.generations}\t{goal_field}\n")


