def print_config_show(opts: Options) -> int:
    psp_dir_label = str(opts.psp_dir).replace(str(Path.home()), "~")
    config_file_label = f"{psp_dir_label}/config.toml"
    rows = []
    key_width = max(len(k) for k, _, _ in _CONFIG_SHOW_KEYS)
    for cfg_key, attr, default in _CONFIG_SHOW_KEYS:
        raw = getattr(opts, attr)
        if isinstance(raw, bool):
            value = "true" if raw else "false"
        else:
            value = str(raw) if raw else default
        source = opts._sources.get(cfg_key, "default")
        rows.append((cfg_key, value, source))

    if opts.format_output == "json":
        data = {k: v for k, v, _ in rows}
        data["_sources"] = {k: s for k, _, s in rows}
        sys.stdout.write(json.dumps(data, indent=2) + "\n")
        return 0

    for cfg_key, value, source in rows:
        source_note = f"  ({source})" if source != "default" else c("  (default)", DIM)
        print(f"  {cfg_key:<{key_width}} = {c(value, CYAN)}{source_note}")

    cfg_path = opts.psp_dir / "config.toml"
    print()
    if cfg_path.is_file():
        print(c(f"  config file: {config_file_label}", DIM))
    else:
        print(c(f"  config file: {config_file_label} (not found)", DIM))
    print(c(f"  priority: default < {config_file_label} < PSP_* env vars < CLI flags", DIM))
    return 0


def read_goal(opts: Options) -> None:
    if not sys.stdin.isatty():
        stdin_goal = sys.stdin.read().rstrip("\n")
        match = HISTORY_INPUT_RE.match(stdin_goal)
        if match:
            stdin_goal = match.group(1)
        if stdin_goal:
            opts.goal_text = stdin_goal
            return
        if opts.headless_mode:
            quit_with("No goal provided (use --goal or pipe from stdin in headless mode)")
        return

    if opts.headless_mode:
        quit_with("No goal provided (use --goal or pipe from stdin in headless mode)")

    if opts.goal_text or opts.plan_explicit or opts.init_plan_path:
        return

    if opts.goal_flag:
        opts.goal_text = opts.goal_flag
        return

    print("Goal: ", end="", file=sys.stderr, flush=True)
    try:
        with open("/dev/tty", "r", encoding="utf-8") as tty:
            goal = tty.readline().rstrip("\n")
    except KeyboardInterrupt:
        print(file=sys.stderr)
        raise SystemExit(130)
    if not goal:
        quit_with("No goal provided")
    opts.goal_text = goal


def apply_agent_presets(opts: Options) -> None:
    if opts.agent == "codex":
        if not opts.agent_bin:
            opts.agent_bin = os.environ.get("AGENT_BIN") or os.environ.get("CODEX_BIN") or "codex"
        if not opts.agent_args_text:
            if opts.yolo_mode:
                opts.agent_args_text = "--yolo exec -"
            else:
                opts.agent_args_text = os.environ.get("AGENT_ARGS") or os.environ.get("CODEX_ARGS") or "--full-auto exec -"
        return

    if opts.agent == "claude":
        if not opts.agent_bin:
            opts.agent_bin = os.environ.get("AGENT_BIN") or "claude"
        if not opts.agent_args_text:
            if opts.yolo_mode:
                opts.agent_args_text = "-p --dangerously-skip-permissions -"
            else:
                opts.agent_args_text = os.environ.get("AGENT_ARGS") or "-p -"
        return

    if opts.agent == "opencode":
        if not opts.agent_bin:
            opts.agent_bin = os.environ.get("AGENT_BIN") or "opencode"
        if not opts.agent_args_text:
            opts.agent_args_text = os.environ.get("AGENT_ARGS") or "run -"
        if opts.yolo_mode:
            print("PSP WARNING | --yolo is not supported for opencode; ignored", file=sys.stderr)
        return

    quit_with(f"Unknown agent: {opts.agent}. Valid values: codex, claude, opencode")


def validate(opts: Options) -> None:
    if opts.plan_explicit:
        plan_path = Path(opts.plan_path)
        if not (plan_path.is_file() and os.access(plan_path, os.R_OK)):
            quit_with(f"Plan file is not readable: {opts.plan_path}")

    if not re.fullmatch(r"[1-9][0-9]*", opts.generations):
        quit_with(f"GENERATIONS must be a positive integer: {opts.generations}")
    if not SLEEP_RE.fullmatch(opts.sleep_seconds):
        quit_with(f"SLEEP_SECONDS must be a non-negative number: {opts.sleep_seconds}")
    if not re.fullmatch(r"[0-9]+", opts.time_budget):
        quit_with(f"TIME_BUDGET must be a non-negative integer (seconds): {opts.time_budget}")
    if not re.fullmatch(r"[0-9]+", opts.timeout_seconds):
        quit_with(f"TIMEOUT must be a non-negative integer (seconds): {opts.timeout_seconds}")
    if not re.fullmatch(r"[0-9]+", opts.retry_count):
        quit_with(f"RETRY must be a non-negative integer: {opts.retry_count}")
    if not isinstance(opts.dry_run, bool):
        quit_with(f"DRY_RUN must be a boolean: {opts.dry_run}")
    if opts.output_mode not in {"discard", "inherit", "log"}:
        quit_with(f"OUTPUT_MODE must be 'discard', 'inherit', or 'log': {opts.output_mode}")
    if opts.progress_mode not in {"auto", "plain", "tty"}:
        quit_with(f"PROGRESS_MODE must be 'auto', 'plain', or 'tty': {opts.progress_mode}")


def split_agent_args(agent_args_text: str) -> list[str]:
    return agent_args_text.split() if agent_args_text else []


def bash_quote(value: str) -> str:
    return shlex.quote(value)


def rewrite_plan_goal(plan_path: Path, goal: str) -> str:
    rewritten: list[str] = []
    for line in plan_path.read_text(encoding="utf-8").splitlines(keepends=True):
        if line.startswith("GOAL:"):
            rewritten.append(f"GOAL: {goal}\n")
        else:
            rewritten.append(line)
    return "".join(rewritten)


def git_head(cwd: Path | None = None) -> str:
    completed = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        capture_output=True,
        text=True,
        check=False,
        cwd=str(cwd) if cwd is not None else None,
    )
    if completed.returncode != 0:
        return "nogit"
    return completed.stdout.strip() or "nogit"


def installed_version_sha(script_path: Path) -> str:
    candidates = [
        Path.home() / ".local" / "bin" / ".psp-version",
        resolve_path(script_path).parent / ".psp-version",
    ]
    for version_path in candidates:
        if version_path.is_file():
            return version_path.read_text(encoding="utf-8").strip()
    return ""


def prepare_effective_plan(opts: Options) -> tuple[str, str]:
    tmp_plan = ""
    effective_plan = opts.plan_path
    run_dir = opts.run_dir
    if opts.goal_text and not opts.plan_explicit:
        handle, tmp_plan = tempfile.mkstemp(prefix="plan.tmp.", dir=run_dir)
        os.close(handle)
        Path(tmp_plan).write_text(builtin_plan_template(opts.goal_text, os.path.basename(tmp_plan)), encoding="utf-8")
        effective_plan = tmp_plan
    elif opts.goal_text:
        base_name = Path(opts.plan_path).name
        if "." in base_name:
            base_name = base_name.rsplit(".", 1)[0]
        handle, tmp_plan = tempfile.mkstemp(prefix=f"{base_name}.tmp.", dir=run_dir)
        os.close(handle)
        Path(tmp_plan).write_text(rewrite_plan_goal(Path(opts.plan_path), opts.goal_text), encoding="utf-8")
        effective_plan = tmp_plan
    return effective_plan, tmp_plan


def open_output_target(output_mode: str, path: str | None):
    if output_mode == "discard":
        return open(os.devnull, "w", encoding="utf-8")
    if output_mode == "log" and path is not None:
        return open(path, "w", encoding="utf-8")
    return None


def run_generation_loop(
    opts: Options,
    agent_command: list[str],
    effective_plan: str,
    plan_display: str,
    header_width: int = 0,
) -> int:
    run_ts = ""
    gen_log_paths: list[str] = []
    run_committed: list[str] = []
    run_total = 0
    run_retries = 0
    if opts.output_mode == "log":
        run_ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")

    append_history(opts, plan_display)
    psp_start_time = time.monotonic()
    generations = int(opts.generations)
    gen_w = len(opts.generations)
    sleep_seconds = float(opts.sleep_seconds)
    time_budget = int(opts.time_budget)
    timeout_per_gen = int(opts.timeout_seconds)
    max_retries = int(opts.retry_count)

    for generation in range(1, generations + 1):
        if _shutdown_requested:
            if not opts.quiet_mode:
                print(f"{c('PSP', CYAN, BOLD)} {SEP} {c('signal received, shutting down', YELLOW)}")
            return 130
        if time_budget > 0 and int(time.monotonic() - psp_start_time) >= time_budget:
            if not opts.quiet_mode:
                print(f"{c('PSP', CYAN, BOLD)} {SEP} {c('⏱ time budget reached, stopping', YELLOW)}")
            return 0

        gen_output_path = None
        gen_log_note = ""
        if opts.output_mode == "log":
            gen_output_path = str(opts.run_dir / f"psp_{opts.agent}_{run_ts}_gen{generation:02d}.log")
            gen_log_note = f" → {c('psp/' + Path(gen_output_path).name, DIM)}"
            gen_log_paths.append(gen_output_path)

        def gen_label(icon: str = " ") -> str:
            return c(f"{SEP} {icon} PSP {generation:>{gen_w}}/{generations:<{gen_w}} {SEP}", CYAN)

        generation_start = git_head()
        if not opts.quiet_mode:
            print(f"{gen_label('🔄')} {c('running …', YELLOW)}{gen_log_note}")
        gen_started_at = time.monotonic()

        attempt = 0
        proc = None
        while attempt <= max_retries:
            if attempt > 0:
                run_retries += 1
                backoff = min(2 ** (attempt - 1), 30)
                if not opts.quiet_mode:
                    print(f"{gen_label('🔁')} {c(f'retry {attempt}/{max_retries}, waiting {backoff}s', YELLOW)}")
                try:
                    time.sleep(backoff)
                except KeyboardInterrupt:
                    if not opts.quiet_mode:
                        print(f"\n{gen_label('✗')} {c('interrupted', RED)}", flush=True)
                    return 130

            with open(effective_plan, "r", encoding="utf-8") as stdin_handle:
                output_handle = open_output_target(opts.output_mode, gen_output_path)
                try:
                    env = dict(os.environ)
                    for env_var in opts.env_vars:
                        if "=" in env_var:
                            k, v = env_var.split("=", 1)
                            env[k] = v
                    global _current_proc
                    proc = subprocess.Popen(
                        agent_command,
                        stdin=stdin_handle,
                        stdout=output_handle if output_handle is not None else sys.stdout,
                        stderr=subprocess.STDOUT,
                        text=True,
                        env=env,
                    )
                    _current_proc = proc
                    try:
                        if timeout_per_gen > 0:
                            try:
                                proc.wait(timeout=timeout_per_gen)
                            except subprocess.TimeoutExpired:
                                proc.kill()
                                proc.wait()
                                if not opts.quiet_mode:
                                    print(f"{gen_label('⏱')} {c(f'timeout after {timeout_per_gen}s', RED)}")
                        else:
                            proc.wait()
                    except KeyboardInterrupt:
                        proc.terminate()
                        try:
                            proc.wait(timeout=5)
                        except subprocess.TimeoutExpired:
                            proc.kill()
                        if not opts.quiet_mode:
                            print(f"\n{gen_label('✗')} {c('interrupted', RED)}", flush=True)
                        return 130
                    finally:
                        _current_proc = None
                finally:
                    if output_handle is not None:
                        output_handle.close()

            if proc.returncode == 0 or attempt >= max_retries:
                break
            attempt += 1

        if _shutdown_requested:
            if not opts.quiet_mode:
                print(f"{c('PSP', CYAN, BOLD)} {SEP} {c('signal received, shutting down', YELLOW)}")
            return 130

        if proc.returncode != 0:
            if opts.stop_on_error:
                if not opts.quiet_mode:
                    print(f"{gen_label('✗')} {c(f'agent failed (exit {proc.returncode}), stopping', RED)}")
                return proc.returncode
            if not opts.quiet_mode:
                retry_note = f" (retried {attempt}x)" if attempt > 0 else ""
                print(f"{gen_label('✗')} {c(f'agent failed (exit {proc.returncode}), continuing{retry_note}', RED)}")

        if opts.keep_logs == "never" and gen_output_path:
            Path(gen_output_path).unlink(missing_ok=True)

        took = int(time.monotonic() - gen_started_at)
        generation_end = git_head()
        run_total += 1
        if generation_end == generation_start:
            if not opts.quiet_mode:
                print(f"{gen_label('⚪')} {c('no commit', YELLOW)} {SEP} {c(f'took: {took}s', DIM)}")
        else:
            run_committed.append(generation_end[:7])
            if not opts.quiet_mode:
                print(
                    f"{gen_label('✅')} {c('committed', GREEN)} {c(generation_end[:7], GREEN)} {SEP} {c(f'took: {took}s', DIM)}"
                )

        if opts.verbose_mode and not opts.quiet_mode:
            _print_verbose_timing(generation, took, gen_output_path)

        if opts.diff_mode and not opts.quiet_mode:
            _print_generation_diff(generation, generation_end != generation_start)

        if generation < generations:
            if not opts.quiet_mode:
                print(SEP + LINE * (header_width - 2) + SEP)
            try:
                time.sleep(sleep_seconds)
            except KeyboardInterrupt:
                if not opts.quiet_mode:
                    print(f"\n{gen_label('✗')} {c('interrupted', RED)}", flush=True)
                return 130

    if not opts.quiet_mode:
        print(SEP + LINE * (header_width - 2) + SEP)
    summary = _run_summary(opts.goal_text, gen_log_paths, run_committed, run_total, opts.run_dir)
    if opts.quiet_mode:
        print(summary)
    else:
        print(f"{c(f'{SEP} PSP DONE', CYAN)} {SEP} {summary}")

    if opts.keep_logs == "session":
        for path in gen_log_paths:
            Path(path).unlink(missing_ok=True)

    return 0


def _print_verbose_timing(generation: int, took: int, gen_output_path: str | None) -> None:
    """Print detailed timing info for --verbose mode."""
    parts = [c(f"  [verbose] gen {generation}", DIM)]
    parts.append(c(f"wall: {took}s", CYAN))
    if gen_output_path:
        p = Path(gen_output_path)
        if p.exists():
            size = p.stat().st_size
            if size >= 1024 * 1024:
                size_str = f"{size / (1024 * 1024):.1f} MB"
            elif size >= 1024:
                size_str = f"{size / 1024:.1f} KB"
            else:
                size_str = f"{size} B"
            parts.append(c(f"log: {size_str}", DIM))
    print(" ".join(parts))


def _print_generation_diff(generation: int, has_commit: bool) -> None:
    """Show a compact git diff stat for the current generation."""
    if has_commit:
        result = subprocess.run(
            ["git", "diff", "--stat", "HEAD^"],
            capture_output=True, text=True, check=False,
        )
    else:
        result = subprocess.run(
            ["git", "diff", "--stat", "HEAD"],
            capture_output=True, text=True, check=False,
        )
    if result.returncode == 0 and result.stdout.strip():
        label = "committed" if has_commit else "unstaged"
        print(c(f"  [diff] gen {generation} ({label})", DIM))
        for line in result.stdout.rstrip().splitlines():
            print(f"    {line}")


_SIGNAL_RE = re.compile(
    r"\b(commit|improve|fix|add|remov|refactor|fail|error|skip|revert|decision|reason|because)\b",
    re.IGNORECASE,
)


def _run_summary(goal: str, gen_log_paths: list[str], run_committed: list[str], run_total: int, run_dir: Path) -> str:
    """Return a one-line display summary. If psp/CURRENT_MEMORY.md is absent,
    synthesise it from goal + filtered log lines + results, then write it."""
    memory = run_dir / "CURRENT_MEMORY.md"

    # Synthesise CURRENT_MEMORY.md if absent
    if not memory.exists():
        sections: list[str] = []
        if goal:
            sections.append(f"## Goal\n{goal}")
        for path in gen_log_paths:
            p = Path(path)
            if not p.exists():
                continue
            signal_lines = [
                line for line in p.read_text(encoding="utf-8", errors="replace").splitlines()
                if _SIGNAL_RE.search(line)
            ][:50]
            if signal_lines:
                sections.append(f"## {p.name}\n" + "\n".join(signal_lines))
        if run_total > 0:
            result_section = (
                f"{len(run_committed)}/{run_total} generations committed"
                if run_committed
                else f"{run_total} generations ran, no commits"
            )
            sections.append(f"## Results\n{result_section}")
        if sections:
            memory.write_text(
                "# PSP run memory (auto-generated)\n\n" + "\n\n".join(sections) + "\n",
                encoding="utf-8",
            )

    # Build display line
    result_line = ""
    if run_total > 0:
        result_line = (
            f"{len(run_committed)}/{run_total} committed"
            if run_committed
            else f"0/{run_total} committed"
        )
    result_colour = GREEN if run_committed else YELLOW

    goal_display = ""
    if goal:
        flat = " ".join(goal.split())
        short = flat if len(flat) <= 40 else flat[:40] + "…"
        goal_display = c("goal: ", DIM) + c(short, CYAN)

    if not memory.exists():
        parts = [c("◎ run complete", DIM)]
        if goal_display:
            parts.append(goal_display)
        if result_line:
            parts.append(c(result_line, result_colour))
        return f" {SEP} ".join(parts)

    mem_label = c("◎ psp/CURRENT_MEMORY.md", GREEN) + c(" generated", DIM)
    parts = [mem_label]
    if goal_display:
        parts.append(goal_display)
    if result_line:
        parts.append(c(result_line, result_colour))
    return f" {SEP} ".join(parts)


def print_last_run(opts: Options) -> int:
    """Show the most recent run summary (from --history and logs)."""
    goals = read_history_goals(opts.psp_dir)
    rows = read_log_rows(opts.run_dir)
    if not goals and not rows:
        print("No previous runs found.", file=sys.stderr)
        return 1

    if opts.format_output == "json":
        import json
        data: dict[str, Any] = {}
        if goals:
            data["last_goal"] = goals[-1]
            data["total_goals"] = len(goals)
        if rows:
            data["logs"] = [
                {"path": r.path, "agent": r.agent, "generation": r.generation, "timestamp": r.run_timestamp}
                for r in rows[-10:]
            ]
        sys.stdout.write(json.dumps(data, indent=2) + "\n")
        return 0

    if goals:
        print(f"{c('Last goal:', DIM)} {c(goals[-1], CYAN)}")
        print(f"{c('Total runs:', DIM)} {len(goals)}")
    if rows:
        print(f"{c('Logs in cwd:', DIM)} {len(rows)}")
        for r in rows[-5:]:
            print(f"  {c(r.agent, YELLOW)} gen {r.generation}  {c(r.run_timestamp, DIM)}  {r.path}")
    return 0


def print_stats(opts: Options) -> int:
    """Show run statistics from history and logs."""
    goals = read_history_goals(opts.psp_dir)
    rows = read_log_rows(opts.run_dir)
    if not goals and not rows:
        print("No runs found.", file=sys.stderr)
        return 1

    if opts.format_output == "json":
        data: dict[str, Any] = {
            "total_goals": len(goals),
            "total_logs": len(rows),
        }
        agent_counts: dict[str, int] = {}
        for r in rows:
            agent_counts[r.agent] = agent_counts.get(r.agent, 0) + 1
        data["agents"] = agent_counts
        sys.stdout.write(json.dumps(data, indent=2) + "\n")
        return 0

    print(f"{c('Total goals:', DIM)} {len(goals)}")
    print(f"{c('Total logs:', DIM)} {len(rows)}")
    agent_counts: dict[str, int] = {}
    for r in rows:
        agent_counts[r.agent] = agent_counts.get(r.agent, 0) + 1
    if agent_counts:
        print(f"{c('By agent:', DIM)}")
        for agent, count in sorted(agent_counts.items(), key=lambda x: -x[1]):
            print(f"  {c(agent, YELLOW)}: {count}")
    return 0


def follow_current_log(opts: Options) -> int:
    """Tail the most recent generation log file."""
    rows = read_log_rows(opts.run_dir)
    if not rows:
        print("No generation logs found in current directory.", file=sys.stderr)
        return 1
    latest = rows[-1].path
    try:
        subprocess.run(["tail", "-f", latest], check=False)
    except KeyboardInterrupt:
        pass
    return 0



def _init_colors_for_opts(opts: Options) -> None:
    """Initialize color system after config/env/CLI resolution."""
    global _COLOR_ENABLED
    _COLOR_ENABLED = not opts.no_color and sys.stdout.isatty()
    _init_colors()


def _resolve_runtime_options(opts: Options) -> None:
    """Apply config, env, and presentation settings in precedence order."""
    _load_config_for_opts(opts)
    _apply_env_overrides(opts)
    _init_colors_for_opts(opts)


def _load_config_for_opts(opts: Options) -> None:
    """Load config file(s) unless --clean is set."""
    if opts.clean_mode:
        return
    if opts.config_path:
        cfg = Path(opts.config_path)
        if not cfg.is_file():
            quit_with(f"Config file not found: {opts.config_path}")
        _load_config_file(opts, cfg, opts.config_path)
    else:
        load_config(opts)


def _resolve_cwd(opts: Options) -> None:
    """Change working directory if --cwd was given."""
    if not opts.cwd_override:
        return
    cwd_path = Path(opts.cwd_override).resolve()
    if not cwd_path.is_dir():
        quit_with(f"Directory not found: {opts.cwd_override}")
    os.chdir(cwd_path)


def _build_agent_command(opts: Options) -> list[str]:
    """Build the agent command with all arguments."""
    agent_args = split_agent_args(opts.agent_args_text)
    if opts.max_turns:
        agent_args.extend(["--max-turns", opts.max_turns])
    return [opts.agent_bin, *agent_args]


def _print_header(
    opts: Options,
    plan_display: str,
    goal_note: str,
    nm_w: int,
) -> int:
    """Print the header banner and return its display width."""
    yolo_note = (f" {SEP} {c('⚠ yolo', RED, BOLD)}") if opts.yolo_mode else ""
    label = c(f"{SEP} PSP {'STEP':<{nm_w}} {SEP} ", CYAN)
    body = f"{c('plan:', DIM)} {plan_display}{goal_note} {SEP} {c('agent:', DIM)} {c(opts.agent, YELLOW)} {SEP} {c('gen:', DIM)} {opts.generations}{yolo_note} "
    header = f"{label}{body}{SEP}"
    print(header)
    return len(re.sub(r"\033\[[0-9;]*m", "", header))


def _build_goal_note(opts: Options) -> str:
    """Build the goal display snippet for the header."""
    if not opts.goal_text:
        return ""
    flat = " ".join(opts.goal_text.split())
    g = flat[:33] + (" …" if len(flat) > 33 else "")
    return f" {SEP} {c('goal:', DIM)} {c(g, CYAN)}"


def _run_dry_run(
    opts: Options,
    agent_command: list[str],
    header_width: int,
) -> int:
    """Print the resolved command and exit."""
    plan_display = opts.plan_path if opts.plan_explicit else "(builtin)"
    if not opts.no_banner:
        _print_header(opts, plan_display, _build_goal_note(opts), max(len(opts.generations) * 2 + 1, len("STEP")))
    command_text = "".join(f" {bash_quote(part)}" for part in agent_command)
    if not opts.plan_explicit:
        print(f"PSP DRY RUN |{command_text} < <(builtin_plan_template {bash_quote(opts.goal_text)})")
    else:
        print(f"PSP DRY RUN |{command_text} < {bash_quote(opts.plan_path)}")
    return 0


def _run_loop(
    opts: Options,
    agent_command: list[str],
    header_width: int,
) -> int:
    """Prepare the plan and run the generation loop."""
    if shutil.which(opts.agent_bin) is None:
        warn_if_no_agent()
        quit_with(f"Required command not found on PATH: {opts.agent_bin}")

    if not os.path.isabs(opts.plan_path):
        opts.plan_path = f"{Path.cwd()}/{opts.plan_path}"

    effective_plan, tmp_plan = prepare_effective_plan(opts)
    plan_display = ("psp/" + os.path.basename(tmp_plan)) if tmp_plan else opts.plan_path
    if not opts.no_banner:
        _print_header(opts, plan_display, _build_goal_note(opts), max(len(opts.generations) * 2 + 1, len("STEP")))
    try:
        return run_generation_loop(opts, agent_command, effective_plan, plan_display, header_width)
    finally:
        if tmp_plan:
            Path(tmp_plan).unlink(missing_ok=True)


def _handle_non_run_modes(opts: Options, argv: list[str]) -> int | None:
    """Handle modes that return before generation execution begins."""
    if opts.config_show:
        return print_config_show(opts)
    if opts.print_plan:
        return _handle_print_plan(opts)
    if opts.install_mode:
        install_self(opts)
        return 0
    if opts.fzf_mode:
        pick_goal_with_fzf(opts.script_path, [a for a in argv if a != "--fzf"])
        return 0
    if opts.last_mode:
        return print_last_run(opts)
    if opts.follow_mode:
        return follow_current_log(opts)
    if opts.stats_mode:
        return print_stats(opts)
    return None


def main(argv: list[str]) -> int:
    sys.stdout.reconfigure(line_buffering=True)
    _register_signal_handlers()
    script_path = resolve_path(Path(__file__))
    opts = Options(script_path=script_path, script_dir=script_path.parent)

    parsed = parse_args(opts, argv)
    if parsed is not None:
        return parsed

    _resolve_runtime_options(opts)

    early_result = _handle_non_run_modes(opts, argv)
    if early_result is not None:
        return early_result

    if opts.continue_mode and not opts.goal_text:
        goals = read_history_goals(opts.psp_dir)
        if not goals:
            quit_with("No history to continue from")
        opts.goal_text = goals[-1]

    _resolve_cwd(opts)
    read_goal(opts)

    if opts.init_plan_path:
        return _handle_init_plan(opts)

    apply_agent_presets(opts)
    validate(opts)

    agent_command = _build_agent_command(opts)
    nm_w = max(len(opts.generations) * 2 + 1, len("STEP"))
    header_width = nm_w * 2 + 1

    if opts.dry_run:
        return _run_dry_run(opts, agent_command, header_width)

    return _run_loop(opts, agent_command, header_width)


def _handle_print_plan(opts: Options) -> int:
    """Handle --print-plan: print the effective plan and exit."""
    if not opts.goal_text:
        if opts.plan_explicit:
            plan_text = Path(opts.plan_path).read_text(encoding="utf-8")
            sys.stdout.write(plan_text)
            return 0
        read_goal(opts)
        if not opts.goal_text:
            quit_with("--print-plan requires a goal (--goal or stdin) or an explicit plan (--plan)")
    effective_plan, tmp_plan = prepare_effective_plan(opts)
    try:
        plan_text = Path(effective_plan).read_text(encoding="utf-8")
        sys.stdout.write(plan_text)
        return 0
    finally:
        if tmp_plan:
            Path(tmp_plan).unlink(missing_ok=True)


def _handle_init_plan(opts: Options) -> int:
    """Handle --init-plan: write a starter plan file and exit."""
    init_plan_path = Path(opts.init_plan_path)
    if init_plan_path.exists():
        quit_with(f"Refusing to overwrite existing file: {opts.init_plan_path}")
    init_plan_path.write_text(
        builtin_plan_template("[[describe the improvement you want here]]"),
        encoding="utf-8",
    )
    print(f"Wrote starter plan to {opts.init_plan_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
