#!/usr/bin/env python3
from __future__ import annotations

import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import TextIO


CONFIG_TEMPLATE = """# ~/.psp/config.toml — PSP user defaults
# Priority: this file < command-line flags
# All keys are optional; uncomment and edit the ones you want.

# agent       = "codex"       # codex | claude | opencode
# generations = 10            # number of self-play generations
# sleep       = 2             # seconds to pause between generations
# time_budget = 0             # wall-clock cap in seconds (0 = no limit)
# output      = "log"         # discard | inherit | log  (default: log = per-generation files in $PWD)
# agent_bin   = ""            # override the agent executable path
# agent_args  = ""            # override the full agent argument string
# yolo        = false         # true = pass --yolo / --dangerously-skip-permissions
"""

BUILTIN_PLAN_TEMPLATE = """DOMAIN: the current working directory and its contents.

GOAL: {goal}

LEARN FROM CURRENT MEMORY: read CURRENT_MEMORY.md first if it exists.

LEARN FROM PREVIOUS RUNS: read any local agent_*.md notes that seem relevant before changing anything so you extend the existing trajectory instead of restarting it.

APPLY SKILLS: before designing, read any skill_*.md files in this repo and apply relevant ones to your approach.
DEAD ENDS: before designing, read FAILED_PATHS.md if it exists and never re-try any listed approach. When you abandon an approach, append it to FAILED_PATHS.md with a one-line reason.

STRATEGY: use a 90%/10% probability split between refining the strongest current path and testing one mutation that could outperform it.

RETHINK: after the first design, pause and say exactly "Wait, let me rethink, how can I do this differently." Then improve the design based on rethink.

AT TASK COMPLETION: if the repo explicitly allows report files, write a UTC-timestamped agent_<topic>_memory.md with decisions, failed ideas, metrics, and reusable lessons.

RESULTS LEDGER: the runner maintains results.tsv as a tab-separated run ledger with timestamp, generation, status, commit, and note.

UPDATE CURRENT MEMORY: if this run produced a lesson likely to help upcoming runs in this repo, merge it into CURRENT_MEMORY.md in concise form.

WRITE SKILLS: promote a lesson into skill_<topic>.md only when it is reusable, concrete, and likely to help many future runs. Do not create a skill for a one-off repo quirk, a weak hunch, or a trick that succeeded only once.

SKILL HYGIENE: patch an existing skill when refining the same technique; create a new skill only for a genuinely different technique. Keep skills short, actionable, and low-duplication.

SELECTION:
- if the result is clearly better, create a local git commit whose message says what changed and what improved
- otherwise, `git reset` the repo to its pre-task state

CONSTRAINTS: work only inside this repo; never scan outside it; wrap every `find`, `rg`, or `grep` with `timeout` no longer than 10 minutes; prefer reversible edits; treat protected control files (such as PLAN files) as fixed unless the goal explicitly puts them in scope.
"""

HISTORY_INPUT_RE = re.compile(
    r"^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z\t[^\t]*\t[^\t]*\tg=[^\t]*\t(.*)$",
    re.DOTALL,
)
CONFIG_LINE_RE = re.compile(
    r"^[ \t]*([a-zA-Z_][a-zA-Z0-9_-]*)[ \t]*=[ \t]*(.*)[ \t]*$"
)
SLEEP_RE = re.compile(r"^([0-9]+([.][0-9]+)?|[.][0-9]+)$")
SAFE_SHELL_RE = re.compile(r"^[A-Za-z0-9_./:-]+$")


@dataclass
class Options:
    script_path: Path
    script_dir: Path
    agent: str = "codex"
    plan_path: str = ""
    plan_explicit: bool = False
    agent_bin: str = ""
    agent_args_text: str = ""
    goal_text: str = ""
    generations: str = "10"
    sleep_seconds: str = "2"
    time_budget: str = "0"
    output_mode: str = "log"
    dry_run: int = 0
    install_mode: int = 0
    plan_seen: int = 0
    init_plan_path: str = ""
    yolo_mode: int = 0
    results_path: str = ""

    def __post_init__(self) -> None:
        if not self.plan_path:
            self.plan_path = f"{Path.cwd()}/plan.template.txt"
        self.plan_explicit = bool(os.environ.get("PLAN_PATH"))

    @property
    def psp_dir(self) -> Path:
        return Path(os.environ.get("PSP_DIR", str(Path.home() / ".psp")))


def quit_with(message: str) -> "NoReturn":
    print(message, file=sys.stderr)
    raise SystemExit(1)


def resolve_path(path: Path) -> Path:
    return path.resolve()


def builtin_plan_template(goal: str) -> str:
    return BUILTIN_PLAN_TEMPLATE.format(goal=goal)


def ensure_results_ledger(results_path: str) -> None:
    if not results_path:
        return
    path = Path(results_path)
    if not path.exists():
        path.write_text("timestamp_utc\tgeneration\tstatus\tcommit\tnote\n", encoding="utf-8")


def append_result(results_path: str, generation: int, status: str, commit: str, note: str) -> None:
    if not results_path:
        return
    ensure_results_ledger(results_path)
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    with Path(results_path).open("a", encoding="utf-8") as handle:
        handle.write(f"{timestamp}\t{generation}\t{status}\t{commit or '-'}\t{note}\n")


def load_config(opts: Options) -> None:
    cfg = opts.psp_dir / "config.toml"
    if not cfg.is_file():
        return

    for raw_line in cfg.read_text(encoding="utf-8").splitlines():
        stripped = raw_line.lstrip()
        if not stripped or stripped.startswith("#") or stripped.startswith("["):
            continue
        match = CONFIG_LINE_RE.match(raw_line)
        if not match:
            continue

        key, value = match.groups()
        if value.startswith('"'):
            value = value[1:].split('"', 1)[0]
        elif value.startswith("'"):
            value = value[1:].split("'", 1)[0]
        else:
            value = re.sub(r"[ \t]+#.*$", "", value).rstrip(" \t")

        if key == "agent":
            opts.agent = value
        elif key == "generations":
            opts.generations = value
        elif key == "sleep":
            opts.sleep_seconds = value
        elif key == "time_budget":
            opts.time_budget = value
        elif key == "output":
            opts.output_mode = value
        elif key == "agent_bin":
            opts.agent_bin = value
        elif key == "agent_args":
            opts.agent_args_text = value
        elif key == "yolo" and value == "true":
            opts.yolo_mode = 1


def write_default_config(psp_dir: Path) -> int:
    cfg = psp_dir / "config.toml"
    psp_dir.mkdir(parents=True, exist_ok=True)
    if cfg.exists():
        print(f"Config already exists: {cfg}")
        return 1
    cfg.write_text(CONFIG_TEMPLATE, encoding="utf-8")
    print(f"Wrote default config to {cfg}")
    return 0


def init_all(psp_dir: Path) -> None:
    print(f"PSP dir: {psp_dir}")
    try:
        write_default_config(psp_dir)
    except SystemExit:
        raise


def path_block_state(rc_path: Path) -> str:
    start = "# >>> psp >>>"
    end = "# <<< psp <<<"
    export_line = 'export PATH="$HOME/.local/bin:$PATH"'
    if not rc_path.exists():
        return "missing"
    content = rc_path.read_text(encoding="utf-8")
    lines = content.splitlines()
    if export_line in lines:
        return "present"
    has_start = start in content
    has_end = end in content
    if has_start and has_end:
        return "present"
    if has_start or has_end:
        return "partial"
    return "absent"


def ensure_path_block(rc_path: Path) -> None:
    state = path_block_state(rc_path)
    if state == "present":
        print(f"PATH already configured in {rc_path}")
        return
    if state == "partial":
        quit_with(f"Refusing to edit {rc_path} because it contains a partial PSP marker block")

    rc_path.parent.mkdir(parents=True, exist_ok=True)
    if not rc_path.exists():
        rc_path.touch()
    elif rc_path.stat().st_size > 0:
        with rc_path.open("a", encoding="utf-8") as handle:
            handle.write("\n")

    with rc_path.open("a", encoding="utf-8") as handle:
        handle.write('# >>> psp >>>\nexport PATH="$HOME/.local/bin:$PATH"\n# <<< psp <<<\n')
    print(f"Updated {rc_path}")


def install_symlink(script_path: Path) -> None:
    bin_dir = Path.home() / ".local" / "bin"
    link_path = bin_dir / "psp"
    bin_dir.mkdir(parents=True, exist_ok=True)
    if link_path.is_symlink():
        if resolve_path(link_path) == script_path:
            print(f"Launcher already installed: {link_path} -> {script_path}")
            return
        quit_with(f"Refusing to overwrite existing symlink: {link_path}")
    if link_path.exists():
        quit_with(f"Refusing to overwrite existing file: {link_path}")
    link_path.symlink_to(script_path)
    print(f"Installed launcher: {link_path} -> {script_path}")


def install_self(opts: Options) -> None:
    print(f"Installing PSP from {opts.script_dir}")
    init_all(opts.psp_dir)
    install_symlink(opts.script_path)
    ensure_path_block(Path.home() / ".zshrc")
    ensure_path_block(Path.home() / ".bashrc")
    print("Install complete. Open a new shell, then run: psp --help")


def append_history(opts: Options, plan_display: str) -> None:
    opts.psp_dir.mkdir(parents=True, exist_ok=True)
    history_path = opts.psp_dir / "history"
    goal_field = opts.goal_text if opts.goal_text else f"(plan: {plan_display})"
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    with history_path.open("a", encoding="utf-8") as handle:
        handle.write(f"{timestamp}\t{opts.agent}\t{Path.cwd()}\tg={opts.generations}\t{goal_field}\n")


def usage(prog: str, *, stream: TextIO | None = None) -> None:
    if stream is None:
        stream = sys.stdout
    stream.write(
        f"""Usage: {prog} [options] [plan-path]
       echo "GOAL" | {prog} [options]
Replay a pure-text PLAN through a coding agent (codex, claude, or opencode).
When stdin is a pipe the goal is read from it; a plan file is optional.

Options:
  --agent codex|claude|opencode, -a  Coding agent to use (default: codex)
  --plan PATH, -p                    Plan file to replay
  --install                          Install psp to ~/.local/bin and wire PATH in ~/.zshrc and ~/.bashrc
  --init                             Initialise ~/.psp/config.toml and exit
  --init-plan [PATH], -i             Write a starter plan file and exit (default: plan.template.txt)
  --init-config                      Write a starter ~/.psp/config.toml and exit
  --yolo                             Use the unsafe permission-bypass preset for the selected agent
  --generations N, -g                Positive integer (default: 10)
  --sleep SECONDS, -s                Non-negative delay between generations
  --time-budget SECONDS, -t          Stop after this many wall-clock seconds (0 = no limit)
  --output discard|inherit|log, -o   Agent output handling (default: log = per-generation files)
  --agent-bin PATH                   Agent executable override
  --agent-args STRING, -x            Full agent args override (replaces preset defaults)
  --dry-run                          Print the resolved command and exit
  --history                          Print ~/.psp/history and exit (pipe through fzf | psp to re-run)
  -h, --help                         Show this help text

Agent presets (overridable via --agent-args):
  codex     -> codex --full-auto exec -
  claude    -> claude -p -
  opencode  -> opencode run -

Config:      ~/.psp/config.toml  (key = value defaults; CLI flags override)
             ~/.psp/history      (append-only run log; browse with --history)
"""
    )


def arg_value(argv: list[str], index: int, option: str) -> str:
    if index + 1 >= len(argv) or argv[index + 1] == "":
        quit_with(f"Missing value for {option}")
    return argv[index + 1]


def set_plan(opts: Options, path: str) -> None:
    if opts.plan_seen:
        quit_with("Provide the plan path once")
    opts.plan_seen = 1
    opts.plan_explicit = True
    opts.plan_path = path


def print_history(psp_dir: Path) -> int:
    history_path = psp_dir / "history"
    if not history_path.is_file():
        print("No history yet.", file=sys.stderr)
        return 0

    seen: set[str] = set()
    for line in history_path.read_text(encoding="utf-8").splitlines():
        if "\t" not in line:
            goal = line
        else:
            parts = line.split("\t")
            goal = parts[4] if len(parts) >= 5 else ""
        if goal in seen:
            continue
        seen.add(goal)
        print(goal)
    return 0


def parse_args(opts: Options, argv: list[str]) -> int | None:
    index = 0
    prog = Path(sys.argv[0]).name
    while index < len(argv):
        current = argv[index]
        if current in ("-h", "--help"):
            usage(prog)
            return 0
        if current == "--install":
            opts.install_mode = 1
        elif current == "--init":
            init_all(opts.psp_dir)
            return 0
        elif current == "--init-config":
            return write_default_config(opts.psp_dir)
        elif current == "--history":
            return print_history(opts.psp_dir)
        elif current == "--dry-run":
            opts.dry_run = 1
        elif current in ("-a", "--agent"):
            opts.agent = arg_value(argv, index, current)
            index += 1
        elif current in ("-p", "--plan"):
            set_plan(opts, arg_value(argv, index, current))
            index += 1
        elif current in ("-i", "--init-plan"):
            if index + 1 < len(argv) and not argv[index + 1].startswith("-"):
                opts.init_plan_path = argv[index + 1]
                index += 1
            else:
                opts.init_plan_path = "plan.template.txt"
        elif current == "--yolo":
            opts.yolo_mode = 1
        elif current in ("-g", "--generations"):
            opts.generations = arg_value(argv, index, current)
            index += 1
        elif current.startswith("-g") and current != "-g":
            opts.generations = current[2:]
        elif current in ("-s", "--sleep"):
            opts.sleep_seconds = arg_value(argv, index, current)
            index += 1
        elif current in ("-t", "--time-budget"):
            opts.time_budget = arg_value(argv, index, current)
            index += 1
        elif current in ("-o", "--output"):
            opts.output_mode = arg_value(argv, index, current)
            index += 1
        elif current in ("--agent-bin", "--codex-bin"):
            opts.agent_bin = arg_value(argv, index, current)
            index += 1
        elif current in ("-x", "--agent-args", "--codex-args"):
            opts.agent_args_text = arg_value(argv, index, current)
            index += 1
        elif current == "--":
            index += 1
            if index >= len(argv):
                quit_with("Missing plan path after --")
            set_plan(opts, argv[index])
        elif current.startswith("-"):
            usage(prog, stream=sys.stderr)
            quit_with(f"Unknown option: {current}")
        else:
            set_plan(opts, current)
        index += 1
    return None


def read_goal(opts: Options) -> None:
    if not sys.stdin.isatty():
        stdin_goal = sys.stdin.read().rstrip("\n")
        match = HISTORY_INPUT_RE.match(stdin_goal)
        if match:
            stdin_goal = match.group(1)
        if stdin_goal:
            opts.goal_text = stdin_goal
        return

    if opts.goal_text or opts.plan_explicit or opts.init_plan_path:
        return

    print("Goal: ", end="", file=sys.stderr, flush=True)
    with open("/dev/tty", "r", encoding="utf-8") as tty:
        goal = tty.readline().rstrip("\n")
    if not goal:
        quit_with("No goal provided")
    opts.goal_text = goal


def apply_agent_presets(opts: Options) -> None:
    if opts.agent == "codex":
        if not opts.agent_bin:
            opts.agent_bin = os.environ.get("AGENT_BIN") or os.environ.get("CODEX_BIN") or "codex"
        if not opts.agent_args_text:
            if opts.yolo_mode:
                opts.agent_args_text = "--yolo exec -"
            else:
                opts.agent_args_text = os.environ.get("AGENT_ARGS") or os.environ.get("CODEX_ARGS") or "--full-auto exec -"
        return

    if opts.agent == "claude":
        if not opts.agent_bin:
            opts.agent_bin = os.environ.get("AGENT_BIN") or "claude"
        if not opts.agent_args_text:
            if opts.yolo_mode:
                opts.agent_args_text = "-p --dangerously-skip-permissions -"
            else:
                opts.agent_args_text = os.environ.get("AGENT_ARGS") or "-p -"
        return

    if opts.agent == "opencode":
        if not opts.agent_bin:
            opts.agent_bin = os.environ.get("AGENT_BIN") or "opencode"
        if not opts.agent_args_text:
            opts.agent_args_text = os.environ.get("AGENT_ARGS") or "run -"
        if opts.yolo_mode:
            print("PSP WARNING | --yolo is not supported for opencode; ignored", file=sys.stderr)
        return

    quit_with(f"Unknown agent: {opts.agent}. Valid values: codex, claude, opencode")


def validate(opts: Options) -> None:
    if not opts.goal_text or opts.plan_explicit:
        plan_path = Path(opts.plan_path)
        if not (plan_path.is_file() and os.access(plan_path, os.R_OK)):
            quit_with(f"Plan file is not readable: {opts.plan_path}")

    if not re.fullmatch(r"[1-9][0-9]*", opts.generations):
        quit_with(f"GENERATIONS must be a positive integer: {opts.generations}")
    if not SLEEP_RE.fullmatch(opts.sleep_seconds):
        quit_with(f"SLEEP_SECONDS must be a non-negative number: {opts.sleep_seconds}")
    if not re.fullmatch(r"[0-9]+", opts.time_budget):
        quit_with(f"TIME_BUDGET must be a non-negative integer (seconds): {opts.time_budget}")
    if opts.dry_run not in (0, 1):
        quit_with(f"DRY_RUN must be 0 or 1: {opts.dry_run}")
    if opts.output_mode not in {"discard", "inherit", "log"}:
        quit_with(f"OUTPUT_MODE must be 'discard', 'inherit', or 'log': {opts.output_mode}")


def split_agent_args(agent_args_text: str) -> list[str]:
    return agent_args_text.split() if agent_args_text else []


def bash_quote(value: str) -> str:
    if value == "":
        return "''"
    if SAFE_SHELL_RE.fullmatch(value):
        return value

    escaped: list[str] = []
    for char in value:
        if char.isalnum() or char in "_./:-":
            escaped.append(char)
        else:
            escaped.append(f"\\{char}")
    return "".join(escaped)


def rewrite_plan_goal(plan_path: Path, goal: str) -> str:
    rewritten: list[str] = []
    for line in plan_path.read_text(encoding="utf-8").splitlines(keepends=True):
        if line.startswith("GOAL:"):
            rewritten.append(f"GOAL: {goal}\n")
        else:
            rewritten.append(line)
    return "".join(rewritten)


def git_head() -> str:
    completed = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        capture_output=True,
        text=True,
        check=False,
    )
    if completed.returncode != 0:
        return "nogit"
    return completed.stdout.strip() or "nogit"


def prepare_effective_plan(opts: Options) -> tuple[str, str]:
    tmp_plan = ""
    effective_plan = opts.plan_path
    cwd = Path.cwd()
    if opts.goal_text and not opts.plan_explicit:
        handle, tmp_plan = tempfile.mkstemp(prefix="plan.tmp.", dir=cwd)
        os.close(handle)
        Path(tmp_plan).write_text(builtin_plan_template(opts.goal_text), encoding="utf-8")
        effective_plan = tmp_plan
    elif opts.goal_text:
        base_name = Path(opts.plan_path).name
        if "." in base_name:
            base_name = base_name.rsplit(".", 1)[0]
        handle, tmp_plan = tempfile.mkstemp(prefix=f"{base_name}.tmp.", dir=cwd)
        os.close(handle)
        Path(tmp_plan).write_text(rewrite_plan_goal(Path(opts.plan_path), opts.goal_text), encoding="utf-8")
        effective_plan = tmp_plan
    return effective_plan, tmp_plan


def open_output_target(output_mode: str, path: str | None):
    if output_mode == "discard":
        return open(os.devnull, "w", encoding="utf-8")
    if output_mode == "log" and path is not None:
        return open(path, "w", encoding="utf-8")
    return None


def run_generation_loop(
    opts: Options,
    agent_command: list[str],
    effective_plan: str,
    plan_display: str,
) -> int:
    opts.results_path = f"{Path.cwd()}/results.tsv"
    ensure_results_ledger(opts.results_path)

    run_ts = ""
    if opts.output_mode == "log":
        run_ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")

    append_history(opts, plan_display)
    psp_start_time = time.monotonic()
    generations = int(opts.generations)
    gen_w = len(opts.generations)
    sleep_seconds = float(opts.sleep_seconds)
    time_budget = int(opts.time_budget)

    for generation in range(1, generations + 1):
        if time_budget > 0 and int(time.monotonic() - psp_start_time) >= time_budget:
            print(
                f"PSP | time budget of {time_budget}s reached before generation {generation}/{generations}, stopping"
            )
            return 0

        gen_output_path = None
        gen_log_note = ""
        if opts.output_mode == "log":
            gen_output_path = f"{Path.cwd()}/psp_{opts.agent}_{run_ts}_gen{generation:02d}.log"
            gen_log_note = f" → {Path(gen_output_path).name}"

        generation_start = git_head()
        print(f"| PSP {generation:>{gen_w}}/{generations:<{gen_w}} | running...{gen_log_note} |")
        gen_started_at = time.monotonic()

        with open(effective_plan, "r", encoding="utf-8") as stdin_handle:
            output_handle = open_output_target(opts.output_mode, gen_output_path)
            try:
                completed = subprocess.run(
                    agent_command,
                    stdin=stdin_handle,
                    stdout=output_handle if output_handle is not None else sys.stdout,
                    stderr=subprocess.STDOUT,
                    text=True,
                    check=False,
                )
            finally:
                if output_handle is not None:
                    output_handle.close()

        if completed.returncode != 0:
            return completed.returncode

        took = int(time.monotonic() - gen_started_at)
        generation_end = git_head()
        if generation_end == generation_start:
            append_result(opts.results_path, generation, "no_commit", "-", "no new commit")
            print(
                f"| PSP {generation:>{gen_w}}/{generations:<{gen_w}} | running → no commit | took: {took}s |"
            )
        else:
            append_result(opts.results_path, generation, "committed", generation_end, "HEAD advanced")
            print(
                f"| PSP {generation:>{gen_w}}/{generations:<{gen_w}} | running → committed {generation_end[:7]} | took: {took}s |"
            )

        if generation < generations:
            time.sleep(sleep_seconds)

    return 1


def main(argv: list[str]) -> int:
    script_path = resolve_path(Path(__file__))
    opts = Options(script_path=script_path, script_dir=script_path.parent)
    load_config(opts)

    parsed = parse_args(opts, argv)
    if parsed is not None:
        return parsed

    if opts.install_mode:
        install_self(opts)
        return 0

    read_goal(opts)

    if opts.init_plan_path:
        init_plan_path = Path(opts.init_plan_path)
        if init_plan_path.exists():
            quit_with(f"Refusing to overwrite existing file: {opts.init_plan_path}")
        init_plan_path.write_text(
            builtin_plan_template("describe the improvement you want here"),
            encoding="utf-8",
        )
        print(f"Wrote starter plan to {opts.init_plan_path}")
        return 0

    apply_agent_presets(opts)
    validate(opts)

    agent_args = split_agent_args(opts.agent_args_text)
    agent_command = [opts.agent_bin, *agent_args]

    plan_display = opts.plan_path
    if opts.goal_text and not opts.plan_explicit:
        plan_display = "(builtin)"

    gen_w = len(opts.generations)
    nm_w = gen_w * 2 + 1
    yolo_note = " | yolo: yes" if opts.yolo_mode else ""
    if opts.plan_explicit:
        print(
            f"| PSP {'RUN':<{nm_w}} | plan: {plan_display} | agent: {opts.agent} | generations: {opts.generations}{yolo_note} |"
        )
    else:
        print(
            f"| PSP {'RUN':<{nm_w}} | goal: {opts.goal_text} | agent: {opts.agent} | generations: {opts.generations}{yolo_note} |"
        )

    if opts.dry_run == 1:
        command_text = "".join(f" {bash_quote(part)}" for part in agent_command)
        if plan_display == "(builtin)":
            print(f"PSP DRY RUN |{command_text} < <(builtin_plan_template {bash_quote(opts.goal_text)})")
        else:
            print(f"PSP DRY RUN |{command_text} < {bash_quote(opts.plan_path)}")
        return 0

    if shutil.which(opts.agent_bin) is None:
        quit_with(f"Required command not found on PATH: {opts.agent_bin}")

    if not os.path.isabs(opts.plan_path):
        opts.plan_path = f"{Path.cwd()}/{opts.plan_path}"

    effective_plan, tmp_plan = prepare_effective_plan(opts)
    try:
        return run_generation_loop(opts, agent_command, effective_plan, plan_display)
    finally:
        if tmp_plan:
            Path(tmp_plan).unlink(missing_ok=True)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
