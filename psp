def warn_if_no_agent() -> None:
    missing = [name for name, _ in _AGENT_INSTALL_HINTS if shutil.which(name) is None]
    if len(missing) < len(_AGENT_INSTALL_HINTS):
        return  # at least one agent present
    print("\nNo agent found on PATH. Install one to get started:")
    for name, hint in _AGENT_INSTALL_HINTS:
        print(f"  {name:<10}→  {hint}")
    print()


def append_history(opts: Options, plan_display: str) -> None:
    opts.psp_dir.mkdir(parents=True, exist_ok=True)
    history_path = opts.psp_dir / "history"
    raw = opts.goal_text if opts.goal_text else f"(plan: {plan_display})"
    goal_field = " ".join(raw.split())
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    with history_path.open("a", encoding="utf-8") as handle:
        handle.write(f"{timestamp}\t{opts.agent}\t{Path.cwd()}\tg={opts.generations}\t{goal_field}\n")


def usage(prog: str, *, stream: TextIO | None = None) -> None:
    if stream is None:
        stream = sys.stdout
    option_width = max(len(option) for option, _ in _HELP_OPTIONS)
    option_lines = "\n".join(
        f"  {option:<{option_width}}  {description}"
        for option, description in _HELP_OPTIONS
    )
    stream.write(
        f"""Usage: {prog} [options] [plan-path]
       echo "GOAL" | {prog} [options]
Replay a pure-text PLAN through a coding agent (codex, claude, or opencode).
When stdin is a pipe the goal is read from it; a plan file is optional.

Options:
{option_lines}

Agent presets (overridable via --agent-args):
  codex     -> codex --full-auto exec -
  claude    -> claude -p -
  opencode  -> opencode run -

Config:      ~/.psp/config.toml  (key = value defaults; CLI flags override)
             ~/.psp/history      (append-only run log; browse with --history)

Tab completion in bash/zsh:
  source <(psp --generate-completion)

"""
    )


def arg_value(argv: list[str], index: int, option: str) -> str:
    if index + 1 >= len(argv) or argv[index + 1] == "":
        quit_with(f"Missing value for {option}")
    return argv[index + 1]


def set_plan(opts: Options, path: str) -> None:
    if opts.plan_seen:
        quit_with("Provide the plan path once")
    opts.plan_seen = True
    opts.plan_explicit = True
    opts.plan_path = path


@dataclass(frozen=True)
class LogRow:
    path: str
    filename: str
    agent: str
    run_timestamp: str
    generation: str


def read_log_rows(workdir: Path) -> list[LogRow]:
    rows: list[LogRow] = []
    for path in sorted(workdir.glob("psp_*_gen*.log")):
        match = re.match(r"^psp_(.+)_([0-9]{8}T[0-9]{6}Z)_gen([0-9]+)\.log$", path.name)
        if match is None:
            continue
        agent, run_timestamp, generation = match.groups()
        rows.append(
            LogRow(
                path=str(path),
                filename=path.name,
                agent=agent,
                run_timestamp=run_timestamp,
                generation=str(int(generation)),
            )
        )
    rows.sort(key=lambda row: (row.run_timestamp, int(row.generation), row.filename))
    return rows



def pick_goal_with_fzf(script_path: Path, extra_args: list[str]) -> None:
    if shutil.which("fzf") is None:
        quit_with("fzf not found on PATH")
    psp = shlex.quote(str(script_path))
    extra = " ".join(shlex.quote(a) for a in extra_args)
    os.execvp("sh", ["sh", "-c", f"goal=$({psp} --history | fzf) && printf '%s' \"$goal\" | {psp} {extra}"])
    return None  # unreachable (execvp replaces process)


def build_history_fzf_command(script_path: Path, extra_args: list[str]) -> str:
    psp = shlex.quote(str(script_path))
    extra = " ".join(shlex.quote(a) for a in extra_args)
    return f"goal=$({psp} --history | fzf) && printf '%s' \"$goal\" | {psp} {extra}"


def read_history_goals(psp_dir: Path) -> list[str]:
    history_path = psp_dir / "history"
    if not history_path.is_file():
        return []
    seen: set[str] = set()
    goals: list[str] = []
    for line in history_path.read_text(encoding="utf-8").splitlines():
        goal = line if "\t" not in line else (line.split("\t")[4] if len(line.split("\t")) >= 5 else "")
        if goal and goal not in seen:
            seen.add(goal)
            goals.append(goal)
    return goals


def print_history(psp_dir: Path, format_output: str = "", tac: bool = False) -> int:
    goals = read_history_goals(psp_dir)
    if not goals:
        print("No history yet.", file=sys.stderr)
        return 0
    if tac:
        goals = list(reversed(goals))
    if format_output == "json":
        sys.stdout.write(json.dumps({"goals": goals, "count": len(goals)}, indent=2) + "\n")
        return 0
    plain = "\n".join(goals) + "\n"
    if sys.stdout.isatty():
        pager = os.environ.get("PAGER", "").strip()
        pager_cmd = shlex.split(pager) if pager else ["less", "-FRX", "+G"]
        if pager_cmd and pager_cmd[0] == "less" and "+G" not in pager_cmd:
            pager_cmd.append("+G")
        if pager_cmd and shutil.which(pager_cmd[0]):
            spaced = re.sub(r"^", "\n", plain, flags=re.M)
            subprocess.run(pager_cmd, input=spaced, text=True, check=False)
            return 0
    sys.stdout.write(plain)
    return 0


def print_logs(workdir: Path, format_output: str = "", tac: bool = False) -> int:
    rows = read_log_rows(workdir)
    if not rows:
        print("No generation logs found in current directory.", file=sys.stderr)
        return 0
    if tac:
        rows = list(reversed(rows))
    if format_output == "json":
        data = [
            {"path": r.path, "agent": r.agent, "generation": r.generation, "timestamp": r.run_timestamp}
            for r in rows
        ]
        sys.stdout.write(json.dumps(data, indent=2) + "\n")
        return 0
    for row in rows:
        print(row.path)
    return 0


