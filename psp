def generate_completion() -> int:
    # Emit both scripts: zsh guards with $ZSH_VERSION, bash runs unconditionally.
    # Safe to source in either shell with: source <(psp --generate-completion)
    sys.stdout.write("if [ -n \"$ZSH_VERSION\" ]; then\n")
    sys.stdout.write(_COMPLETION_ZSH)
    sys.stdout.write("else\n")
    sys.stdout.write(_COMPLETION_BASH)
    sys.stdout.write("fi\n")
    return 0


def parse_args(opts: Options, argv: list[str]) -> int | None:
    index = 0
    prog = Path(sys.argv[0]).name
    while index < len(argv):
        current = argv[index]
        if current in ("-h", "--help"):
            usage(prog)
            return 0
        if current in ("-V", "--version"):
            commit = installed_version_sha(Path(sys.argv[0]))
            suffix = f" ({commit[:7]})" if commit else ""
            print(f"psp {VERSION}{suffix}")
            return 0
        if current == "--install":
            opts.install_mode = True
        elif current == "--history":
            opts.history_mode = True
        elif current in ("--continue", "-C"):
            opts.continue_mode = True
        elif current in ("--goal", "-G"):
            opts.goal_flag = arg_value(argv, index, current)
            index += 1
        elif current == "--fzf":
            opts.fzf_mode = True
        elif current == "--logs":
            opts.logs_mode = True
        elif current == "--no-color":
            opts.no_color = True
            opts._sources["no_color"] = current
        elif current in ("--quiet", "-q"):
            opts.quiet_mode = True
            opts._sources["quiet"] = current
        elif current == "--stop-on-error":
            opts.stop_on_error = True
            opts._sources["stop_on_error"] = current
        elif current == "--cwd":
            opts.cwd_override = arg_value(argv, index, current)
            index += 1
        elif current == "--verbose":
            opts.verbose_mode = True
            opts._sources["verbose"] = current
        elif current == "--print-plan":
            opts.print_plan = True
        elif current == "--config-show":
            opts.config_show = True
        elif current == "--generate-completion":
            return generate_completion()
        elif current == "--dry-run":
            opts.dry_run = True
        elif current == "--no-banner":
            opts.no_banner = True
            opts._sources["no_banner"] = current
        elif current == "--model":
            opts.model = arg_value(argv, index, current)
            opts._sources["model"] = current
            index += 1
        elif current == "--config":
            opts.config_path = arg_value(argv, index, current)
            index += 1
        elif current == "--env":
            opts.env_vars.append(arg_value(argv, index, current))
            index += 1
        elif current in ("--headless", "--no-input"):
            opts.headless_mode = True
            opts._sources["headless"] = current
        elif current == "--max-turns":
            opts.max_turns = arg_value(argv, index, current)
            opts._sources["max_turns"] = current
            index += 1
        elif current == "--diff":
            opts.diff_mode = True
            opts._sources["diff_mode"] = current
        elif current == "--clean":
            opts.clean_mode = True
            opts._sources["clean_mode"] = current
        elif current in ("--last", "-L"):
            opts.last_mode = True
        elif current == "--format":
            opts.format_output = arg_value(argv, index, current)
            index += 1
        elif current in ("--follow", "-f"):
            opts.follow_mode = True
        elif current in ("--generation-timeout", "--timeout"):
            opts.timeout_seconds = arg_value(argv, index, current)
            opts._sources["timeout"] = current
            index += 1
        elif current == "--retry":
            opts.retry_count = arg_value(argv, index, current)
            opts._sources["retry"] = current
            index += 1
        elif current == "--tac":
            opts.tac_mode = True
        elif current == "--stats":
            opts.stats_mode = True
        elif current == "--progress":
            val = arg_value(argv, index, current)
            if val not in ("auto", "plain", "tty"):
                quit_with(f"--progress must be auto, plain, or tty (got: {val!r})")
            opts.progress_mode = val
            opts._sources["progress"] = current
            index += 1
        elif current in ("-a", "--agent"):
            opts.agent = arg_value(argv, index, current)
            opts._sources["agent"] = current
            index += 1
        elif current in ("-p", "--plan"):
            set_plan(opts, arg_value(argv, index, current))
            index += 1
        elif current in ("-i", "--init-plan"):
            if index + 1 < len(argv) and not argv[index + 1].startswith("-"):
                opts.init_plan_path = argv[index + 1]
                index += 1
            else:
                opts.init_plan_path = "plan.template.txt"
        elif current == "--yolo":
            opts.yolo_mode = True
            opts._sources["yolo"] = current
        elif current == "--keep-logs":
            val = arg_value(argv, index, current)
            if val not in ("always", "session", "never"):
                quit_with(f"--keep-logs must be always, session, or never (got: {val!r})")
            opts.keep_logs = val
            opts._sources["keep_logs"] = current
            index += 1
        elif current == "--keep-log":
            opts.keep_logs = "always"
            opts._sources["keep_logs"] = current
        elif current in ("-g", "--generations"):
            opts.generations = arg_value(argv, index, current)
            opts._sources["generations"] = current
            index += 1
        elif current.startswith("-g") and current != "-g":
            opts.generations = current[2:]
            opts._sources["generations"] = current
        elif current in ("-s", "--sleep"):
            opts.sleep_seconds = arg_value(argv, index, current)
            opts._sources["sleep"] = current
            index += 1
        elif current in ("-t", "--time-budget"):
            opts.time_budget = arg_value(argv, index, current)
            opts._sources["time_budget"] = current
            index += 1
        elif current in ("-o", "--output"):
            opts.output_mode = arg_value(argv, index, current)
            opts._sources["output"] = current
            index += 1
        elif current in ("--agent-bin", "--codex-bin"):
            opts.agent_bin = arg_value(argv, index, current)
            opts._sources["agent_bin"] = current
            index += 1
        elif current in ("-x", "--agent-args", "--codex-args"):
            opts.agent_args_text = arg_value(argv, index, current)
            opts._sources["agent_args"] = current
            index += 1
        elif current == "--":
            index += 1
            if index >= len(argv):
                quit_with("Missing plan path after --")
            set_plan(opts, argv[index])
        elif current.startswith("-"):
            usage(prog, stream=sys.stderr)
            quit_with(f"Unknown option: {current}")
        else:
            set_plan(opts, current)
        index += 1
    if opts.history_mode:
        return print_history(opts.psp_dir, opts.format_output, opts.tac_mode)
    if opts.logs_mode:
        return print_logs(opts.run_dir, opts.format_output, opts.tac_mode)
    return None


