def _parse_cfg_value(raw: str) -> str:
    """Strip quotes and inline comments from a config value."""
    if raw.startswith('"'):
        return raw[1:].split('"', 1)[0]
    if raw.startswith("'"):
        return raw[1:].split("'", 1)[0]
    return re.sub(r"[ \t]+#.*$", "", raw).rstrip(" \t")


def _load_config_file(opts: Options, cfg: Path, label: str) -> None:
    """Load config from a specific file path."""
    if not cfg.is_file():
        return

    for raw_line in cfg.read_text(encoding="utf-8").splitlines():
        stripped = raw_line.lstrip()
        if not stripped or stripped.startswith("#") or stripped.startswith("["):
            continue
        match = CONFIG_LINE_RE.match(raw_line)
        if not match:
            continue

        key, raw_value = match.groups()
        value = _parse_cfg_value(raw_value)
        handler = _CONFIG_HANDLERS.get(key)
        if handler is None:
            continue
        handler(opts, value, label)


def load_config(opts: Options) -> None:
    cfg = opts.psp_dir / "config.toml"
    if not cfg.is_file():
        return

    label = f"~/.psp/config.toml"
    _load_config_file(opts, cfg, label)


# ── Environment variable overrides (PSP_* prefix) ───────────────────────────
# Pattern from docker (DOCKER_HOST), kubectl (KUBECONFIG), etc.
# Priority: default < config file < env vars < CLI flags

def _env_bool(name: str) -> str | None:
    """Read a PSP_* env var and return 'true'/'false' or None."""
    val = os.environ.get(name)
    if val is None:
        return None
    return "true" if val.lower() in ("1", "true", "yes", "on") else "false"

def _env_str(name: str) -> str | None:
    """Read a PSP_* env var and return its value or None."""
    val = os.environ.get(name)
    return val if val else None

def _apply_env_overrides(opts: Options) -> None:
    """Apply PSP_* environment variable overrides.

    These sit between config file and CLI flags in the priority chain.
    Only overrides that are explicitly set in the environment are applied.
    """
    env_map = [
        ("PSP_AGENT",         "agent",         "agent",         "str"),
        ("PSP_GENERATIONS",   "generations",   "generations",   "str"),
        ("PSP_SLEEP",         "sleep_seconds", "sleep",         "str"),
        ("PSP_TIME_BUDGET",   "time_budget",   "time_budget",   "str"),
        ("PSP_OUTPUT",        "output_mode",   "output",        "str"),
        ("PSP_AGENT_BIN",     "agent_bin",     "agent_bin",     "str"),
        ("PSP_AGENT_ARGS",    "agent_args_text", "agent_args",  "str"),
        ("PSP_YOLO",          "yolo_mode",     "yolo",          "bool"),
        ("PSP_KEEP_LOGS",     "keep_logs",     "keep_logs",     "keep_logs"),
        ("PSP_QUIET",         "quiet_mode",    "quiet",         "bool"),
        ("PSP_STOP_ON_ERROR", "stop_on_error", "stop_on_error", "bool"),
        ("PSP_VERBOSE",       "verbose_mode",  "verbose",       "bool"),
        ("PSP_NO_COLOR",      "no_color",      "no_color",      "bool"),
        ("PSP_NO_BANNER",     "no_banner",     "no_banner",     "bool"),
        ("PSP_MODEL",         "model",         "model",         "str"),
        ("PSP_HEADLESS",      "headless_mode", "headless",      "bool"),
        ("PSP_MAX_TURNS",     "max_turns",     "max_turns",     "str"),
        ("PSP_DIFF",          "diff_mode",     "diff_mode",     "bool"),
        ("PSP_CLEAN",         "clean_mode",    "clean_mode",    "bool"),
        ("PSP_TIMEOUT",       "timeout_seconds", "timeout",     "str"),
        ("PSP_RETRY",         "retry_count",   "retry",         "str"),
        ("PSP_TAC",           "tac_mode",      "tac",           "bool"),
        ("PSP_STATS",         "stats_mode",    "stats",         "bool"),
        ("PSP_PROGRESS",      "progress_mode", "progress",      "str"),
    ]

    for env_name, attr, src_key, kind in env_map:
        if not _can_apply_env_value(opts, src_key):
            continue
        if kind == "bool":
            val = _env_bool(env_name)
            if val is not None:
                setattr(opts, attr, val == "true")
                opts._sources[src_key] = f"env:{env_name}"
        elif kind == "keep_logs":
            val = _env_str(env_name)
            if val is not None:
                if val in ("always", "session", "never"):
                    opts.keep_logs = val
                elif val.lower() in ("1", "true", "yes"):
                    opts.keep_logs = "always"
                elif val.lower() in ("0", "false", "no"):
                    opts.keep_logs = "session"
                opts._sources[src_key] = f"env:{env_name}"
        elif kind == "str":
            val = _env_str(env_name)
            if val is not None:
                if attr == "progress_mode" and val not in ("auto", "plain", "tty"):
                    quit_with(f"PSP_PROGRESS must be auto, plain, or tty (got: {val!r})")
                if attr == "output_mode" and val not in ("discard", "inherit", "log"):
                    quit_with(f"PSP_OUTPUT must be discard, inherit, or log (got: {val!r})")
                if attr == "agent" and val not in ("codex", "claude", "opencode"):
                    quit_with(f"PSP_AGENT must be codex, claude, or opencode (got: {val!r})")
                setattr(opts, attr, val)
                opts._sources[src_key] = f"env:{env_name}"


def write_default_config(psp_dir: Path) -> int:
    cfg = psp_dir / "config.toml"
    psp_dir.mkdir(parents=True, exist_ok=True)
    if cfg.exists():
        print(f"Config already exists: {cfg}")
        return 1
    cfg.write_text(CONFIG_TEMPLATE, encoding="utf-8")
    print(f"Wrote default config to {cfg}")
    return 0


def init_all(psp_dir: Path) -> None:
    print(f"PSP dir: {psp_dir}")
    try:
        write_default_config(psp_dir)
    except SystemExit:
        raise


def path_block_state(rc_path: Path) -> str:
    start = "# >>> psp >>>"
    end = "# <<< psp <<<"
    export_line = 'export PATH="$HOME/.local/bin:$PATH"'
    if not rc_path.exists():
        return "missing"
    content = rc_path.read_text(encoding="utf-8")
    lines = content.splitlines()
    if export_line in lines:
        return "present"
    has_start = start in content
    has_end = end in content
    if has_start and has_end:
        return "present"
    if has_start or has_end:
        return "partial"
    return "absent"


def ensure_path_block(rc_path: Path) -> None:
    state = path_block_state(rc_path)
    if state == "present":
        print(f"PATH already configured in {rc_path}")
        return
    if state == "partial":
        quit_with(f"Refusing to edit {rc_path} because it contains a partial PSP marker block")

    rc_path.parent.mkdir(parents=True, exist_ok=True)
    if not rc_path.exists():
        rc_path.touch()
    elif rc_path.stat().st_size > 0:
        with rc_path.open("a", encoding="utf-8") as handle:
            handle.write("\n")

    with rc_path.open("a", encoding="utf-8") as handle:
        handle.write('# >>> psp >>>\nexport PATH="$HOME/.local/bin:$PATH"\n# <<< psp <<<\n')
    print(f"Updated {rc_path}")


def install_symlink(script_path: Path) -> None:
    bin_dir = Path.home() / ".local" / "bin"
    link_path = bin_dir / "psp"
    bin_dir.mkdir(parents=True, exist_ok=True)
    if link_path.is_symlink():
        if resolve_path(link_path) == script_path:
            print(f"Launcher already installed: {link_path} -> {script_path}")
            return
        quit_with(f"Refusing to overwrite existing symlink: {link_path}")
    if link_path.exists():
        quit_with(f"Refusing to overwrite existing file: {link_path}")
    link_path.symlink_to(script_path)
    print(f"Installed launcher: {link_path} -> {script_path}")


def install_nano(script_dir: Path) -> None:
    nano_src = script_dir / "psp-nano"
    if not nano_src.is_file():
        print(f"psp-nano not found in {script_dir}, skipping")
        return
    bin_dir = Path.home() / ".local" / "bin"
    link_path = bin_dir / "psp-nano"
    bin_dir.mkdir(parents=True, exist_ok=True)
    if link_path.is_symlink():
        if resolve_path(link_path) == resolve_path(nano_src):
            print(f"Launcher already installed: {link_path} -> {nano_src}")
            return
        quit_with(f"Refusing to overwrite existing symlink: {link_path}")
    if link_path.exists():
        quit_with(f"Refusing to overwrite existing file: {link_path}")
    link_path.symlink_to(nano_src)
    print(f"Installed launcher: {link_path} -> {nano_src}")


def write_installed_version_file(script_path: Path) -> None:
    bin_dir = Path.home() / ".local" / "bin"
    version_path = bin_dir / ".psp-version"
    bin_dir.mkdir(parents=True, exist_ok=True)
    commit = git_head(script_path.parent)
    if commit == "nogit":
        if version_path.exists():
            version_path.unlink()
        return
    version_path.write_text(f"{commit}\n", encoding="utf-8")


def install_self(opts: Options) -> None:
    print(f"Installing PSP from {opts.script_dir}")
    init_all(opts.psp_dir)
    install_symlink(opts.script_path)
    install_nano(opts.script_dir)
    write_installed_version_file(opts.script_path)
    ensure_path_block(Path.home() / ".zshrc")
    ensure_path_block(Path.home() / ".bashrc")
    bin_dir = str(Path.home() / ".local" / "bin")
    path_dirs = os.environ.get("PATH", "").split(":")
    if bin_dir in path_dirs:
        print("Install complete. Run: psp --help")
    else:
        print("Install complete. Activate in your current shell:")
        print(f'  export PATH="{bin_dir}:$PATH"')
        print("Or open a new terminal — your rc file is already updated.")
    warn_if_no_agent()


