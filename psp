def quit_with(message: str) -> NoReturn:
    print(message, file=sys.stderr)
    raise SystemExit(1)


def resolve_path(path: Path) -> Path:
    return path.resolve()


def builtin_plan_template(goal: str, plan_file: str = "") -> str:
    return BUILTIN_PLAN_TEMPLATE.format(goal=goal, plan_file=plan_file or "plan.tmp.*")


def _source_is_cli(label: str | None) -> bool:
    return bool(label) and label.startswith("-")


def _can_apply_config_value(opts: Options, src_key: str) -> bool:
    source = opts._sources.get(src_key)
    if source is None:
        return True
    return not (_source_is_cli(source) or str(source).startswith("env:"))


def _can_apply_env_value(opts: Options, src_key: str) -> bool:
    source = opts._sources.get(src_key)
    if source is None:
        return True
    return not _source_is_cli(source)



def _cfg_str(opts: Options, value: str, label: str, attr: str, src_key: str) -> None:
    """Set a string config attribute."""
    if not _can_apply_config_value(opts, src_key):
        return
    setattr(opts, attr, value)
    opts._sources[src_key] = label


def _cfg_bool(opts: Options, value: str, label: str, attr: str, src_key: str) -> None:
    """Set a bool config attribute when value is 'true'."""
    if not _can_apply_config_value(opts, src_key):
        return
    if value == "true":
        setattr(opts, attr, True)
        opts._sources[src_key] = label


def _cfg_keep_logs(opts: Options, value: str, label: str, _attr: str, src_key: str) -> None:
    """Handle keep_logs with legacy bool compatibility."""
    if not _can_apply_config_value(opts, src_key):
        return
    if value in ("always", "session", "never"):
        opts.keep_logs = value
        opts._sources[src_key] = label
    elif value == "true":
        opts.keep_logs = "always"
        opts._sources[src_key] = label
    elif value == "false":
        opts.keep_logs = "session"
        opts._sources[src_key] = label



