#!/usr/bin/env bash
# psp-nano - minimal self-play loop
# Usage: echo "GOAL" | psp-nano [-a AGENT] [-g N] [-p PLAN]

set -euo pipefail

AGENT="codex"
GENERATIONS=10
PLAN_PATH=""
GOAL=""

# --- parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -a|--agent)       AGENT="$2";       shift 2 ;;
    -g|--generations) GENERATIONS="$2"; shift 2 ;;
    -p|--plan)        PLAN_PATH="$2";   shift 2 ;;
    -h|--help)
      echo "Usage: echo GOAL | psp-nano [-a codex|claude|opencode] [-g N] [-p PLAN]"
      exit 0 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# --- agent preset ---
case "$AGENT" in
  codex)    AGENT_CMD="codex --full-auto --ask-for-approval never exec -" ;;
  claude)   AGENT_CMD="claude -p -" ;;
  opencode) AGENT_CMD="opencode run -" ;;
  *)        echo "Unknown agent: $AGENT" >&2; exit 1 ;;
esac

# --- read goal ---
if [[ ! -t 0 ]]; then
  GOAL=$(cat)
fi
if [[ -z "$GOAL" && -z "$PLAN_PATH" ]]; then
  printf 'Goal: ' >&2
  read -r GOAL </dev/tty || { echo >&2; exit 130; }
  [[ -z "$GOAL" ]] && { echo "No goal provided" >&2; exit 1; }
fi

# --- resolve plan ---
mkdir -p psp

BUILTIN_PLAN=0
TMP_PLAN=""
if [[ -z "$PLAN_PATH" ]]; then
  BUILTIN_PLAN=1
  TMP_PLAN=$(mktemp psp/plan.tmp.XXXXXXXX)
  trap 'rm -f "$TMP_PLAN"' EXIT
fi

RUN_TS=$(date -u +%Y%m%dT%H%M%SZ)
PLAN_DISPLAY="${PLAN_PATH:-${TMP_PLAN}}"
GOAL_DISPLAY="${GOAL:-$(grep "^GOAL:" "$PLAN_DISPLAY" 2>/dev/null | cut -c 7-90)}"
# Show psp/<name> for generated temp plans so the path is findable
if [[ -n "$TMP_PLAN" ]]; then
  PLAN_LABEL="psp/$(basename "$TMP_PLAN")"
else
  PLAN_LABEL="$(basename "$PLAN_DISPLAY")"
fi
echo "| PSP STEP | plan: $PLAN_LABEL | goal: $GOAL_DISPLAY | agent: $AGENT | gen: $GENERATIONS |"

# --- loop ---
for ((i=1; i<=GENERATIONS; i++)); do
  LOG="psp/psp_nano_${RUN_TS}_gen$(printf '%02d' "$i").log"
  echo "| 🔄 PSP $i/$GENERATIONS | running ... $LOG"

  if [[ "$BUILTIN_PLAN" -eq 1 ]]; then
    # Use plan.template.txt if present, else inline template
    if [[ -f plan.template.txt ]]; then
      sed "s/GOAL:.*/GOAL: $GOAL/" plan.template.txt > "$TMP_PLAN"
    else
      cat > "$TMP_PLAN" <<PLAN
DOMAIN: the current working directory and its contents.
GOAL: $GOAL
AUTONOMY: never prompt the user; make every decision yourself.
LEARN FROM PREVIOUS RUNS: read any local psp/agent_*.md notes before changing anything.
STRATEGY: 90% refine the best path, 10% try one mutation.
SELECTION: git commit if better; git reset otherwise; write psp/agent_<topic>.md to summarise your work.
CONSTRAINTS: work only inside this repo; never scan outside it; wrap every `find`, `rg`, or `grep` with `timeout` no longer than 10 minutes; prefer reversible edits; never delete .agent skill files; never delete or modify $TMP_PLAN — it is the runner's active control file for this session.
PLAN
    fi
    $AGENT_CMD < "$TMP_PLAN" >"$LOG" 2>&1
  else
    if [[ -n "$GOAL" ]]; then
      sed "s/GOAL:.*/GOAL: $GOAL/" "$PLAN_PATH" | $AGENT_CMD >"$LOG" 2>&1
    else
      $AGENT_CMD < "$PLAN_PATH" >"$LOG" 2>&1
    fi
  fi

  if (($i % 5 == 0)); then
    echo "| 🧠 PSP $i/$GENERATIONS | skill synthesis ..."
    $AGENT_CMD "Based on all notes in psp/ folder, if a general skill pattern emerges, create a new skill md file under .agents/skill folder. DO NOT modify existing skill, only add new skill if missing."
  fi

  echo "| ✅ PSP $i/$GENERATIONS | done"
  [[ $i -lt $GENERATIONS ]] && sleep 2
done
